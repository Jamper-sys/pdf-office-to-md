Windows Registry Editor Version 5.00

; Añade "Convertir a Markdown" al menú contextual (clic derecho) de
; archivos PDF y de Office en el Explorador de Windows.
; Se instala SOLO para el usuario actual (HKCU), no requiere admin.
;
; Para instalar: doble clic sobre este archivo y aceptar.
; Para desinstalar: doble clic sobre 'desinstalar_menu_contextual.reg'.

[HKEY_CURRENT_USER\Software\Classes\SystemFileAssociations\.pdf\Shell\ConvertirAMd]
@="Convertir a Markdown"
"Icon"="C:\\Users\\javie\\AppData\\Local\\Programs\\Python\\Python312\\pythonw.exe"

[HKEY_CURRENT_USER\Software\Classes\SystemFileAssociations\.pdf\Shell\ConvertirAMd\command]
@="\"C:\\Users\\javie\\AppData\\Local\\Programs\\Python\\Python312\\pythonw.exe\" \"C:\\Users\\javie\\OneDrive - Notley Green Primary School\\Claude\\Convertir a Markdown\\convertir_a_md.pyw\" \"%1\""

